rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isLeagueMember(leagueId) {
      return exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid));
    }

    function isLeagueOwner(leagueId) {
      return get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Users collection — only the owner can read/write their own profile
    // SECURITY: prevent users from setting isAdmin field on themselves
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
                    && !('isAdmin' in request.resource.data);
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
      allow delete: if isOwner(userId);
    }

    // Leagues collection
    match /leagues/{leagueId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isLeagueOwner(leagueId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount', 'updatedAt'])
      );
      allow delete: if isLeagueOwner(leagueId);

      // League members subcollection
      match /members/{memberId} {
        allow read: if isAuthenticated() && (
          isLeagueMember(leagueId) ||
          isLeagueOwner(leagueId) ||
          isOwner(memberId)
        );
        allow create: if isAuthenticated();
        allow update: if isLeagueOwner(leagueId) || isOwner(memberId);
        allow delete: if isLeagueOwner(leagueId) || isOwner(memberId);
      }

      // League invites — members can create (max enforced by Cloud Function rate limit)
      // SECURITY: limit invite doc size to prevent abuse
      match /invites/{inviteId} {
        allow read: if isAuthenticated() && (isLeagueMember(leagueId) || isLeagueOwner(leagueId));
        allow create: if isLeagueMember(leagueId)
                      && request.resource.data.keys().hasOnly(['email', 'status', 'sentBy', 'createdAt'])
                      && request.resource.data.email is string
                      && request.resource.data.email.size() < 256;
        allow update, delete: if isLeagueOwner(leagueId);
      }

      // League announcements subcollection
      match /announcements/{announcementId} {
        allow read: if isAuthenticated() && isLeagueMember(leagueId);
        allow create: if isAuthenticated() && isLeagueOwner(leagueId);
        allow update: if isAuthenticated() && isLeagueOwner(leagueId);
        allow delete: if isAuthenticated() && isLeagueOwner(leagueId);

        match /replies/{replyId} {
          allow read: if isAuthenticated() && isLeagueMember(leagueId);
          allow create, update: if isAuthenticated() && isLeagueMember(leagueId);
          allow delete: if false;
        }
      }

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isLeagueMember(leagueId) || isLeagueOwner(leagueId) || isAdmin());
        allow create: if isAuthenticated() && (isLeagueMember(leagueId) || isLeagueOwner(leagueId))
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && (isLeagueMember(leagueId) || isLeagueOwner(leagueId))
                      && (resource.data.senderId == request.auth.uid
                          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
        allow delete: if isAuthenticated()
                      && (resource.data.senderId == request.auth.uid || isLeagueOwner(leagueId) || isAdmin());
      }

      match /chatReadReceipts/{userId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Drivers collection (read-only for users)
    match /drivers/{driverId} {
      allow read: if true;
      allow write: if false;
    }

    // Constructors collection (read-only for users)
    match /constructors/{constructorId} {
      allow read: if true;
      allow write: if false;
    }

    // Fantasy teams collection
    // SECURITY: prevent userId hijacking, budget manipulation, score tampering
    match /fantasyTeams/{teamId} {
      allow get: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isLeagueMember(resource.data.leagueId) ||
        isLeagueOwner(resource.data.leagueId) ||
        isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Client can only update metadata fields (name, avatar, ace, leagueId).
      // Roster changes (drivers, constructor, budget) go through Cloud Functions.
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'totalPoints', 'lockedPoints', 'scoredRaces',
                      'isLocked', 'lockStatus'
                    ]));
      allow delete: if isOwner(resource.data.userId);
    }

    // Races collection (read-only for users)
    match /races/{raceId} {
      allow read: if true;
      allow write: if false;

      match /results/{resultId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Seasons collection (read-only)
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if false;
    }

    // Price history (read-only)
    match /priceHistory/{historyId} {
      allow read: if true;
      allow write: if false;
    }

    // Collection group query for league members
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == memberId ||
        resource.data.userId == request.auth.uid
      );
    }

    // Articles — authenticated users can read, only admins can write
    match /articles/{articleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Error logs — users can create, only admins can read, immutable
    match /errorLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Purchases collection — users can read their own, only Cloud Functions can write
    match /purchases/{purchaseId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Notifications — users can only read/update their own
    match /notifications/{notificationId} {
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated(); // Firestore can't enforce userId filter on list
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if false;
    }

    // Avatar rate limits — Cloud Functions only
    match /avatarRateLimits/{userId} {
      allow read, write: if false;
    }

    // Pending results — admin only
    match /pendingResults/{resultId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Race scores — per-driver/constructor per-race scoring breakdown (read-only)
    match /raceScores/{scoreId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Game config — readable by all authenticated users, writable by admin only
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Cache — authenticated users can read, only Cloud Functions write
    match /cache/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
